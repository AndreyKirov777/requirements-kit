{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "change-request.schema.json",
  "title": "Change Request frontmatter schema",
  "description": "Schema for CR artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "status", "owner", "affects", "reason", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CR-[A-Z0-9]+-[0-9]{3,}$"
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "applied", "rejected"]
    },
    "affects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Wiki links to affected requirements"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "release_target": {
      "type": "string"
    }
  }
}
