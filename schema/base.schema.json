{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "base.schema.json",
  "title": "Base frontmatter schema",
  "description": "Common fields shared by all artifact types",
  "type": "object",
  "required": ["id", "title", "status", "owner", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(FR|US|NFR|EPIC|ADR|ARCH|CR|TEST|CON|TASK|UC|DM|RISK|REL|PERSONA|JOURNEY|ASSUM|CONTRACT|VISION|BRQ|CTRL|BR|CODEMAP|GLOSS)-[A-Z0-9]+-[0-9]{3,}$",
      "description": "Unique artifact identifier: TYPE-DOMAIN-NNN"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status — allowed values depend on artifact type"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  },
  "additionalProperties": true
}
