{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test.schema.json",
  "title": "Test frontmatter schema",
  "description": "Schema for TEST artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "status", "owner", "verifies", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TEST-[A-Z0-9]+-[0-9]{3,}$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "passed", "failed"]
    },
    "verifies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Wiki links to requirements this test verifies"
    },
    "type": {
      "type": "string",
      "enum": ["unit", "integration", "e2e", "manual", "functional", "non-functional", "security", "performance"]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "covers_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of AC IDs this test covers (e.g., AC-1, AC-3)"
    },
    "verifies_control": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Wiki links to CTRL artifacts this test provides evidence for (compliance-driven projects)"
    }
  }
}
