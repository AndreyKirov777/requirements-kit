{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "release.schema.json",
  "title": "Release frontmatter schema",
  "description": "Schema for REL artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "type", "status", "owner", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REL-[A-Z0-9]+-[0-9]{3,}$"
    },
    "type": {
      "type": "string",
      "const": "release"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "ready", "released", "rolled-back"]
    },
    "release_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "requirements_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "epics_included": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
