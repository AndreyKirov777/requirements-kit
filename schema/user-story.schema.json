{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "user-story.schema.json",
  "title": "User Story frontmatter schema",
  "description": "Schema for US (User Story) artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "status", "priority", "owner", "domain", "persona", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^US-[A-Z0-9]+-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "approved", "in-implementation", "implemented", "verified", "deprecated"]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "persona": {
      "type": "string",
      "description": "Wiki link to the primary persona"
    },
    "parent_epic": {
      "type": "string",
      "description": "Wiki link to the parent Epic"
    },
    "delivers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Wiki links to FRs that this story delivers"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  },
  "additionalProperties": true
}
