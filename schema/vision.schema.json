{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vision.schema.json",
  "title": "Product Vision frontmatter schema",
  "description": "Validates YAML frontmatter for VISION-* artifacts",
  "allOf": [{ "$ref": "base.schema.json" }],
  "type": "object",
  "required": ["id", "title", "status", "owner", "domain", "tags", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^VISION-[A-Z0-9]+-[0-9]{3,}$",
      "description": "Vision artifact ID: VISION-DOMAIN-NNN"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "approved", "superseded", "deprecated"],
      "description": "Lifecycle status — see status-transitions.md"
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Product owner or PM responsible for this vision"
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "description": "Typically 'all' for product-level vision"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "vision" },
      "description": "Must include 'vision' tag"
    }
  }
}
