{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adr.schema.json",
  "title": "ADR frontmatter schema",
  "description": "Schema for Architecture Decision Record artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "status", "owner", "date", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ADR-[A-Z0-9]+-[0-9]{3,}$"
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "superseded", "deprecated"]
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Date the decision was proposed"
    },
    "related_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_by": {
      "type": "string",
      "description": "ID of the ADR that replaces this one"
    }
  }
}
