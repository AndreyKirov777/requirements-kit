{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "journey.schema.json",
  "title": "User journey frontmatter schema",
  "description": "Schema for JOURNEY artifacts",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "type", "status", "owner", "domain", "persona", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^JOURNEY-[A-Z0-9]+-[0-9]{3,}$"
    },
    "type": {
      "type": "string",
      "const": "user-journey"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "approved", "deprecated"]
    },
    "persona": {
      "type": "string"
    },
    "related_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
