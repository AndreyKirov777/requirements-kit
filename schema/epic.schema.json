{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "epic.schema.json",
  "title": "Epic frontmatter schema",
  "description": "Schema for EPIC artifacts. Reverse link (related_requirements) is computed by the traceability script via FR.parent_epic.",
  "allOf": [
    { "$ref": "base.schema.json" }
  ],
  "type": "object",
  "required": ["id", "title", "status", "owner", "domain", "updated"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EPIC-[A-Z0-9]+-[0-9]{3,}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "proposed",
        "approved",
        "in-progress",
        "completed",
        "deprecated"
      ]
    },
    "goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "release_target": {
      "type": "string"
    }
  }
}
